{
  "name": "zipkit",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform ZIP archiver and portability linter/fixer, usable as both a TypeScript SDK and a CLI.",
  "license": "MIT",
  "author": {
    "name": "Yoshinao Inoguchi",
    "email": "nao7sep@gmail.com",
    "url": "https://github.com/nao7sep"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nao7sep/zipkit.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "zipkit": "./bin/zipkit.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsup",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "defu": "^6.1.7",
    "fdir": "^6.4.0",
    "p-limit": "^7.3.0",
    "picomatch": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.7",
    "@types/node": "^25.9.1",
    "@types/picomatch": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
