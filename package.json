{
  "name": "zipkit",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform ZIP archiver and portability linter/fixer: a desktop app and the SDK engine it is built on.",
  "license": "MIT",
  "author": {
    "name": "Yoshinao Inoguchi",
    "email": "nao7sep@gmail.com",
    "url": "https://github.com/nao7sep"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nao7sep/zipkit.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "./out/main/index.js",
  "types": "./src/sdk/index.ts",
  "exports": {
    ".": {
      "types": "./src/sdk/index.ts",
      "import": "./src/sdk/index.ts"
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build:gui": "electron-vite build",
    "dist": "npm run build:gui && electron-builder --publish never",
    "preview": "electron-vite preview",
    "build:mac": "npm run build:gui && electron-builder --mac",
    "build:win": "npm run build:gui && electron-builder --win",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web && npm run typecheck:test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "defu": "^6.1.7",
    "fdir": "^6.5.0",
    "nanoid": "^5.1.16",
    "p-limit": "^7.3.0",
    "picomatch": "^4.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yazl": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/yazl": "^3.3.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  }
}
