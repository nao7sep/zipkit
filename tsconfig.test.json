{
  // Test program: tests/ mirrors src/ and stays out of the shipped build. It runs
  // under BOTH environments — the SDK tests in Node, the renderer-logic and
  // component tests against DOM types — so it carries node + vite/client types and
  // DOM libs. noEmit; never shipped. Wired into `typecheck` so test code is too.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"]
  },
  // The renderer's ambient `Window.zipkit` augmentation is listed because a
  // component test renders components that reach for the bridge (the settings
  // dialog's output-directory picker); without it the test program would see a
  // bare `Window` and fail on code the web program checks fine.
  "include": ["tests/**/*", "vitest.config.ts", "src/gui/renderer/src/env.d.ts"]
}
