{
  // Node-side program: the SDK engine and the GUI's main + preload + shared.
  // `lib: ["ES2022"]` (no DOM) statically catches a node-side file reaching for a
  // browser global; `types: ["node"]` keeps it to Node. Preload sits here because
  // its `electron` import pulls in @types/node, which would otherwise leak Node
  // globals into the renderer.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,
    "noEmit": true,
    "composite": true,
    "outDir": "./out/.tsbuild",
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": [
    "src/sdk/**/*",
    "src/gui/main/**/*",
    "src/gui/preload/**/*",
    "src/gui/shared/**/*",
    "electron.vite.config.ts"
  ]
}
